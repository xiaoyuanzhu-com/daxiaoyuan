/* pages/explore/explore.wxss */

.page {
  min-height: 100vh;
}

/* ---------- Tabs ---------- */
.tabs {
  position: sticky;
  top: 0;
  z-index: 30;
  background: #FFFFFF;
  padding: 16rpx 24rpx 16rpx;
  border-bottom: 1rpx solid rgba(26,24,21,0.10);
  white-space: nowrap;
}

.tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(26,24,21,0.6);
  letter-spacing: 1rpx;
  background: transparent;
  border: 1rpx solid transparent;
}

.tab-active {
  background: #1A1815;
  color: #FFFFFF;
  border-color: #1A1815;
}

/* ---------- List ---------- */
.list {
  padding: 24rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 28rpx;
}

.rank-row-inactive {
  opacity: 0.5;
  border-color: transparent;
}

.rank-row-tap {
  /* mini-program <view> tap with no extra style — relies on hover-class if needed */
}

.rank-num {
  width: 52rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(26,24,21,0.4);
  flex-shrink: 0;
}

.rank-num-top {
  color: #C66A1C;
}

.rank-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.rank-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1815;
  letter-spacing: 1rpx;
  line-height: 1.25;
}

.rank-meta {
  font-size: 22rpx;
  color: rgba(26,24,21,0.6);
}

/* circular percent for cities */
.meter {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(26,24,21,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.meter-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #1A1815;
}

.empty {
  text-align: center;
  padding: 80rpx;
  color: rgba(26,24,21,0.4);
  font-size: 26rpx;
}
