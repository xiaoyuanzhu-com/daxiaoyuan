/* pages/about/about.wxss */

.page {
  min-height: 100vh;
  background: #F6F1E8;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ---- shared typography ---- */
.quote {
  display: block;
  font-size: 36rpx;
  color: #1A1815;
  line-height: 1.75;
  letter-spacing: 4rpx;
  font-weight: 400;
}
.quote-large {
  font-size: 42rpx;
  letter-spacing: 6rpx;
  max-width: 540rpx;
  margin: 0 auto;
  text-align: center;
}
.source {
  display: block;
  margin-top: 32rpx;
  font-size: 22rpx;
  color: rgba(26,24,21,0.4);
  letter-spacing: 3rpx;
}
.prose {
  display: block;
  font-size: 30rpx;
  line-height: 2.0;
  color: #1A1815;
  letter-spacing: 1rpx;
  margin-bottom: 32rpx;
  text-indent: 2em;
}
.prose-faded {
  color: rgba(26,24,21,0.6);
}

/* ---- section spacing ---- */
.section {
  padding: 0 56rpx;
}
.section-yin {
  padding-top: 120rpx;
  padding-bottom: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.section-yin .source {
  text-align: center;
}
.section-shu {
  padding-top: 88rpx;
  padding-bottom: 88rpx;
}
.section-shu .prose:last-child {
  margin-bottom: 0;
}

/* ---- 呼 — gate as 题画 -------- */
.section-hu {
  position: relative;
  padding-top: 112rpx;
  padding-bottom: 104rpx;
  overflow: hidden;
}
.gate {
  position: absolute;
  right: -20rpx;
  bottom: 40rpx;
  width: 600rpx;
  height: 400rpx;
  opacity: 0.20;
  pointer-events: none;
  mix-blend-mode: multiply;
}
.hu-content {
  position: relative;
}
.spacer-md { height: 72rpx; }
.spacer-sm { height: 56rpx; }

/* ---- divider hairline ---- */
.divider {
  width: 64rpx;
  height: 1rpx;
  background: rgba(26,24,21,0.18);
  margin: 0 auto;
}

/* ---- 落款 ---- */
.section-dedication {
  padding-top: 88rpx;
  padding-bottom: 72rpx;
  text-align: center;
}
.dedication {
  display: block;
  font-size: 26rpx;
  color: rgba(26,24,21,0.4);
  letter-spacing: 4rpx;
}

/* ---- repo card ---- */
.repo-card {
  margin: 0 40rpx;
  background: transparent;
  border: 1rpx solid rgba(26,24,21,0.12);
  border-radius: 8rpx;
  padding: 36rpx 36rpx;
}
.repo-card-hover {
  background: rgba(26,24,21,0.03);
}
.repo-kicker {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 3.2rpx;
  color: rgba(26,24,21,0.4);
  text-transform: uppercase;
}
.repo-body {
  display: block;
  font-size: 26rpx;
  color: #1A1815;
  margin-top: 16rpx;
  line-height: 1.6;
  letter-spacing: 0.6rpx;
}
.repo-url {
  display: block;
  font-family: "SF Mono", "Menlo", monospace;
  font-size: 22rpx;
  color: rgba(26,24,21,0.6);
  margin-top: 24rpx;
}
