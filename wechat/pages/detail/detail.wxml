<!--pages/detail/detail.wxml-->
<view wx:if="{{loading}}" class="status-overlay">
  <text class="status-overlay-text">加载中…</text>
</view>

<view wx:if="{{error && !loading}}" class="status-overlay">
  <text class="status-overlay-text">{{error}}</text>
  <button class="status-overlay-btn" bindtap="retry">重试</button>
</view>

<view wx:if="{{!loading && !error && !school}}" class="not-found">
  <text>没有这所学校</text>
</view>

<view wx:if="{{!loading && !error && school}}" class="page c-paper">
  <!-- Hero -->
  <view class="hero {{school.statusBgClass}}">
    <view class="seal serif">{{school.initial}}</view>
    <view wx:if="{{school.address}}" class="hero-district badge small">{{school.address}}</view>
    <text class="hero-name serif">{{school.name}}</text>
    <text class="hero-status">{{school.statusLabel}}</text>
    <view class="hero-meta">
      <view class="clock"></view>
      <text>{{school.updateLabel}}</text>
    </view>
  </view>

  <!-- Campus reservation CTA -->
  <view wx:if="{{school.hasReservation}}" class="section">
    <view class="cta" bindtap="openCampusReservation">
      <text class="cta-label">去预约入校</text>
      <text class="cta-arrow">›</text>
    </view>
  </view>

  <!-- Facilities -->
  <view class="section">
    <text class="section-label">设施</text>
    <view class="fac-list card">
      <view wx:for="{{school.facilitiesList}}" wx:key="key" class="fac-row {{index === 0 ? '' : 'has-border'}}">
        <text class="fac-row-short {{item.bgClass}}">{{item.short}}</text>
        <text class="fac-row-label {{item.muted ? 'muted' : ''}} {{item.strikethrough ? 'strike' : ''}}">{{item.label}}</text>
        <view wx:if="{{item.hasReservation}}"
              class="fac-row-cta"
              data-key="{{item.key}}"
              catchtap="openFacilityReservation">去预约</view>
        <view wx:else class="badge small {{item.bgClass}}">{{item.statusLabel}}</view>
      </view>
    </view>
  </view>
</view>

<!-- Reservation modal -->
<view wx:if="{{modal.visible}}" class="modal-mask" bindtap="closeModal" catchtouchmove="noop">
  <view class="modal-sheet" catchtap="noop">
    <text class="modal-title">{{modal.title}}</text>
    <image class="modal-qrcode"
           src="{{modal.qrcodeUrl}}"
           mode="aspectFit"
           show-menu-by-longpress="{{true}}"
           bindtap="saveQrcode"/>
    <text class="modal-hint-small">长按识别二维码 · 点击保存到相册</text>
    <text wx:if="{{modal.hint}}" class="modal-hint">{{modal.hint}}</text>
    <view wx:if="{{modal.link}}" class="modal-actions">
      <view class="modal-btn" bindtap="copyLink">复制链接</view>
    </view>
    <view class="modal-close" bindtap="closeModal">关闭</view>
  </view>
</view>
