/* pages/detail/detail.wxss */

.page {
  min-height: 100vh;
  padding-bottom: 240rpx;
}

.not-found {
  padding: 80rpx 40rpx;
  text-align: center;
  color: rgba(26,24,21,0.6);
  font-size: 28rpx;
}

/* ---------- Hero ---------- */
.hero {
  padding: 24rpx 40rpx 56rpx;
  position: relative;
  overflow: hidden;
}

.seal {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  border: 3rpx solid currentColor;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 140rpx;
  font-weight: 700;
  opacity: 0.10;
  pointer-events: none;
}

.hero-district {
  display: inline-block;
  background: rgba(255,255,255,0.5);
  color: inherit;
  margin-bottom: 24rpx;
}

.hero-name {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: 2rpx;
}

.hero-status {
  display: block;
  margin-top: 28rpx;
  font-size: 60rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  line-height: 1;
}

.hero-meta {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  opacity: 0.65;
}

.clock {
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  position: relative;
}
.clock::before, .clock::after {
  content: '';
  position: absolute;
  background: currentColor;
}
.clock::before {
  left: 50%;
  top: 50%;
  width: 2rpx;
  height: 6rpx;
  transform: translate(-50%, -100%);
}
.clock::after {
  left: 50%;
  top: 50%;
  width: 4rpx;
  height: 2rpx;
}

/* ---------- Sections ---------- */
.section {
  padding: 40rpx 32rpx 0;
}
.section > .section-label {
  display: block;
  padding-bottom: 24rpx;
}

/* ---------- Entry list ---------- */
.entry-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.entry-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}
.entry-bullet {
  margin-top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #1A1815;
  flex-shrink: 0;
}
.entry-text {
  flex: 1;
  font-size: 28rpx;
  color: #1A1815;
  line-height: 1.55;
  letter-spacing: 0.8rpx;
}

/* ---------- Schedule grid ---------- */
.schedule-grid {
  display: flex;
  background: rgba(26,24,21,0.10);
  border-radius: 16rpx;
  overflow: hidden;
  gap: 2rpx;
}
.schedule-cell {
  flex: 1;
  background: #FFFFFF;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.schedule-label {
  font-size: 20rpx;
  color: rgba(26,24,21,0.4);
  font-weight: 600;
  letter-spacing: 1.6rpx;
}
.schedule-value {
  font-size: 26rpx;
  color: #1A1815;
  font-weight: 500;
}

/* ---------- Facility rows ---------- */
.fac-list {
  overflow: hidden;
}
.fac-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  gap: 20rpx;
}
.fac-row.has-border {
  border-top: 1rpx solid rgba(26,24,21,0.10);
}
.fac-row-short {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.fac-row-label {
  flex: 1;
  font-size: 28rpx;
  color: #1A1815;
  letter-spacing: 0.6rpx;
}
.fac-row-label.muted { color: rgba(26,24,21,0.4); }
.fac-row-label.strike { text-decoration: line-through; }

/* Inline facility-level "去预约" pill — replaces the status badge when bookable */
.fac-row-cta {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.6rpx;
  line-height: 1.1;
  border-radius: 8rpx;
  background: #1A1815;
  color: #FFFFFF;
}
.fac-row-cta:active { opacity: 0.7; }

/* ---------- Campus-level reservation CTA ---------- */
.cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #1A1815;
  color: #FFFFFF;
  border-radius: 16rpx;
  letter-spacing: 1rpx;
}
.cta:active { opacity: 0.85; }
.cta-label { font-size: 30rpx; font-weight: 600; }
.cta-arrow { font-size: 36rpx; line-height: 1; opacity: 0.7; }

/* ---------- Notes ---------- */
.notes {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.note {
  padding: 24rpx 28rpx;
}
.note-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.note-user {
  font-size: 24rpx;
  color: #1A1815;
  font-weight: 600;
}
.note-date {
  font-size: 22rpx;
  color: rgba(26,24,21,0.4);
}
.note-text {
  display: block;
  font-size: 26rpx;
  color: #1A1815;
  line-height: 1.55;
  letter-spacing: 0.6rpx;
}

/* ---------- Reservation modal ---------- */
.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(26,24,21,0.55);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-sheet {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(56rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1815;
  letter-spacing: 1rpx;
  margin-bottom: 32rpx;
}

.modal-qrcode {
  width: 440rpx;
  height: 440rpx;
  background: rgba(26,24,21,0.05);
  border-radius: 16rpx;
}

.modal-hint-small {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: rgba(26,24,21,0.6);
  letter-spacing: 0.8rpx;
}

.modal-hint {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #1A1815;
  line-height: 1.55;
  letter-spacing: 0.6rpx;
  text-align: center;
}

.modal-actions {
  margin-top: 40rpx;
  display: flex;
  gap: 24rpx;
}
.modal-btn {
  padding: 18rpx 40rpx;
  border: 1rpx solid rgba(26,24,21,0.20);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1A1815;
  letter-spacing: 0.6rpx;
}
.modal-btn:active { background: rgba(26,24,21,0.05); }

.modal-close {
  margin-top: 32rpx;
  font-size: 26rpx;
  color: rgba(26,24,21,0.5);
  letter-spacing: 0.6rpx;
}
.modal-close:active { color: #1A1815; }

