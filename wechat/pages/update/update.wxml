<!--pages/update/update.wxml-->
<view class="page c-paper">
  <!-- Top bar (custom — we keep the system nav so a real back chevron is provided) -->

  <!-- Progress dots -->
  <view wx:if="{{step < 4}}" class="progress">
    <view wx:for="{{progressDots}}" wx:key="i" class="bar {{item.filled ? 'filled' : ''}}"></view>
  </view>

  <view class="body">
    <!-- STEP 0: pick a school -->
    <block wx:if="{{step === 0}}">
      <view class="kicker">第 1 步 · 共 4 步</view>
      <view class="title serif">你去的是哪所学校?</view>

      <view class="school-pick-list">
        <view wx:for="{{schools}}" wx:key="id" class="card school-pick" data-id="{{item.id}}" bindtap="pickSchool">
          <view class="school-pick-info">
            <text class="school-pick-name">{{item.name}}</text>
            <text class="school-pick-district">{{item.district}}</text>
          </view>
          <view class="badge small {{item.statusBgClass}}">{{item.statusLabel}}</view>
        </view>
      </view>
    </block>

    <!-- STEP 1: status -->
    <block wx:if="{{step === 1}}">
      <view wx:if="{{school}}" class="school-head">
        <view class="school-head-initial serif {{school.statusBgClass}}">{{school.initial}}</view>
        <view class="school-head-text">
          <text class="school-head-name">{{school.name}}</text>
          <text class="school-head-meta">{{school.district}}</text>
        </view>
      </view>

      <view class="kicker">第 {{schoolId ? 1 : 2}} 步</view>
      <view class="title serif">现在能进吗?</view>
      <view class="sub">基于你的真实体验</view>

      <view class="opt-list">
        <view wx:for="{{statusOpts}}" wx:key="key"
              class="opt {{status === item.key ? 'on ' + item.bgClass : ''}}"
              data-key="{{item.key}}"
              bindtap="pickStatus">
          <view class="dot {{item.dotClass}}"></view>
          <text class="opt-label">{{item.label}}</text>
          <view wx:if="{{status === item.key}}" class="check"></view>
        </view>
      </view>

      <view class="spacer"></view>
      <button class="big-button {{status ? '' : 'disabled'}}" disabled="{{!status}}" bindtap="next">下一步</button>
    </block>

    <!-- STEP 2: facilities -->
    <block wx:if="{{step === 2}}">
      <view wx:if="{{school}}" class="school-head">
        <view class="school-head-initial serif {{school.statusBgClass}}">{{school.initial}}</view>
        <view class="school-head-text">
          <text class="school-head-name">{{school.name}}</text>
          <text class="school-head-meta">{{school.district}}</text>
        </view>
      </view>

      <view class="kicker">第 {{schoolId ? 2 : 3}} 步</view>
      <view class="title serif">哪些设施开放?</view>
      <view class="sub">点击切换:开放 / 不开放 / 不确定</view>

      <view class="opt-list">
        <view wx:for="{{facList}}" wx:key="key"
              class="opt-fac {{item.isUnsure ? '' : 'on'}} {{item.bgClass}}"
              data-key="{{item.key}}"
              bindtap="toggleFac">
          <text class="opt-fac-short">{{item.short}}</text>
          <text class="opt-fac-label">{{item.label}}</text>
          <view class="opt-fac-state">
            <view class="dot smaller {{item.dotClass}}"></view>
            <text>{{item.stateLabel}}</text>
          </view>
        </view>
      </view>

      <view class="spacer"></view>
      <button class="big-button" bindtap="next">下一步</button>
    </block>

    <!-- STEP 3: note -->
    <block wx:if="{{step === 3}}">
      <view wx:if="{{school}}" class="school-head">
        <view class="school-head-initial serif {{school.statusBgClass}}">{{school.initial}}</view>
        <view class="school-head-text">
          <text class="school-head-name">{{school.name}}</text>
          <text class="school-head-meta">{{school.district}}</text>
        </view>
      </view>

      <view class="kicker">第 {{schoolId ? 3 : 4}} 步</view>
      <view class="title serif">想补充什么?</view>
      <view class="sub">选填,可以帮助其他人</view>

      <textarea class="note-input"
                value="{{note}}"
                bindinput="onNote"
                placeholder="比如:今天 9 点从西门进,没排队…"
                placeholder-class="note-input-placeholder"
                maxlength="280"
                auto-height></textarea>

      <view class="transparency">
        <text class="transparency-title">透明承诺</text>
        <text class="transparency-body"> · 你的补充会经过审核,合入数据后会出现在学校页面。原始数据公开存放在 GitHub 上,任何人可以审计。</text>
      </view>

      <view class="spacer"></view>
      <button class="big-button" bindtap="submit">提交</button>
    </block>

    <!-- STEP 4: thanks -->
    <block wx:if="{{step === 4}}">
      <view class="thanks">
        <view class="thanks-check">
          <view class="check-glyph"></view>
        </view>
        <text class="thanks-title serif">收到,感谢!</text>
        <text class="thanks-sub">审核后将合入数据</text>
        <view class="thanks-rank card">
          <view class="thanks-rank-bubble">+1</view>
          <text class="thanks-rank-text">你是这周第 12 个为这所学校提交记录的人</text>
        </view>
        <view class="spacer"></view>
        <button class="big-button" bindtap="done">完成</button>
      </view>
    </block>
  </view>
</view>
