/* pages/home/home.wxss */

.page {
  min-height: 100vh;
  position: relative;
}

.ink40 { color: rgba(26,24,21,0.4); font-size: 22rpx; }

/* ---------- Header ---------- */
.header {
  position: sticky;
  top: 0;
  z-index: 30;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid rgba(26,24,21,0.10);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.city-picker {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.city-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1815;
  letter-spacing: 1.2rpx;
}

.caret {
  width: 22rpx;
  height: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.caret-inner {
  width: 14rpx;
  height: 14rpx;
  border-right: 3rpx solid rgba(26,24,21,0.6);
  border-bottom: 3rpx solid rgba(26,24,21,0.6);
  transform: rotate(45deg) translate(-2rpx, -2rpx);
}

/* ---------- Search ---------- */
.search-icon {
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid rgba(26,24,21,0.6);
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
}
.search-icon::after {
  content: '';
  position: absolute;
  right: -6rpx;
  bottom: -6rpx;
  width: 10rpx;
  height: 3rpx;
  background: rgba(26,24,21,0.6);
  transform: rotate(45deg);
  transform-origin: left center;
}

.header-search {
  flex: 1;
  height: 64rpx;
  background: #F5F5F5;
  border: 1rpx solid rgba(26,24,21,0.10);
  border-radius: 16rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.header-search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #1A1815;
}
.header-search-placeholder {
  font-size: 26rpx;
  color: rgba(26,24,21,0.4);
}
.header-search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(26,24,21,0.4);
}
.header-search-clear-x {
  font-size: 32rpx;
  line-height: 1;
}

/* ---------- Map section ---------- */
.map-section {
  padding: 24rpx 32rpx 24rpx;
  background: #FFFFFF;
}

.map-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(26,24,21,0.10);
}

.campus-map {
  width: 100%;
  height: 100%;
}

/* ---------- List section ---------- */
.list-section {
  padding: 8rpx 32rpx 0;
  display: flex;
  flex-direction: column;
}

/* ---------- school card ---------- */
.school-card {
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 16rpx;
}
.school-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}
.school-card-name-wrap {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.school-logo {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
}
.school-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1815;
  letter-spacing: 1rpx;
  line-height: 1.2;
}
.school-meta {
  font-size: 22rpx;
  color: rgba(26,24,21,0.4);
  margin-top: 4rpx;
}

.school-card-blocks {
  display: flex;
  gap: 12rpx;
}
.block {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0;
}

/* ---------- empty state + list footer ---------- */
.empty {
  text-align: center;
  padding: 80rpx;
  color: rgba(26,24,21,0.4);
  font-size: 26rpx;
}
.list-foot {
  text-align: center;
  padding: 32rpx;
  color: rgba(26,24,21,0.4);
  font-size: 24rpx;
}
