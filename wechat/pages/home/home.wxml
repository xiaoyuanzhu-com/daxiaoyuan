<!--pages/home/home.wxml-->
<view class="page c-paper">
  <!-- Header: city picker (left) + search entry (right) -->
  <view class="header">
    <button class="plain city-picker" bindtap="openCities">
      <text class="city-name">{{cityName}}</text>
      <view class="caret">
        <view class="caret-inner"></view>
      </view>
    </button>

    <view class="header-search">
      <view class="search-icon"></view>
      <input
        class="header-search-input"
        placeholder="搜索学校 · 汉字 / 拼音 / 缩写"
        placeholder-class="header-search-placeholder"
        value="{{query}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <view wx:if="{{query}}" class="header-search-clear" bindtap="clearSearch">
        <text class="header-search-clear-x">×</text>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="status-overlay">
    <text class="status-overlay-text">加载中…</text>
  </view>

  <view wx:if="{{error && !loading}}" class="status-overlay">
    <text class="status-overlay-text">{{error}}</text>
    <button class="status-overlay-btn" bindtap="retry">重试</button>
  </view>

  <!-- Map (always visible) -->
  <view wx:if="{{!loading && !error}}" class="map-section">
    <view class="map-wrap">
      <map id="campusMap"
           class="campus-map"
           latitude="{{cityLat}}"
           longitude="{{cityLng}}"
           scale="12"
           markers="{{mapMarkers}}"
           show-location="{{true}}"
           bindmarkertap="openMarker"></map>
    </view>
  </view>

  <!-- List (always below map) -->
  <view wx:if="{{!loading && !error}}" class="list-section">
    <view wx:for="{{schools}}" wx:for-item="s" wx:key="id" class="card school-card" data-id="{{s.id}}" bindtap="openSchool">
      <view class="school-card-top">
        <view wx:if="{{s.logo}}" class="school-logo" style="background-image: url('{{s.logo}}');"></view>
        <view class="school-card-name-wrap">
          <text class="school-name">{{s.name}}</text>
          <text class="school-meta tnum">{{s.subtitle}}</text>
        </view>
      </view>
      <view class="school-card-blocks">
        <view wx:for="{{s.blocks}}" wx:for-item="b" wx:key="key" class="block {{b.bgClass}}">{{b.short}}</view>
      </view>
    </view>
    <view wx:if="{{schools.length === 0}}" class="empty">没有符合条件的学校</view>

    <view wx:if="{{schools.length > 0 && loadingMore}}" class="list-foot">加载中…</view>
    <view wx:elif="{{schools.length > 0 && !hasMore}}" class="list-foot ink40">没有更多了</view>
  </view>
</view>
